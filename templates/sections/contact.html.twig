<section class="blog-content-area section-padding-100" id="contact">
	<div
		class="container">
		<!-- start portfolio -->
		<h3 class="h3_title">Me contacter</h3>
		<form action="" class="row justify-content-center" id="form-contact">
			<div class="col-lg-6">
				<div class="input_content">
					<div class="form-group">
						<label for="nom">Votre nom *</label>
						<input type="text" class="form-control" id="nom" placeholder="Votre nom ou votre établissement">
					</div>
					<div class="form-group">
						<label for="mail">Votre adresse mail *</label>
						<input type="text" class="form-control" id="mail" placeholder="Votre adresse mail">
					</div>
					<div class="form-group">
						<label for="phone">Votre numero phone (non obligatoir)</label>
						<input type="text" id="phone" class="form-control" placeholder="Numero téléphone">
					</div>
				</div>
			</div>
			<div class="col-lg-6">
				<div class="input_content">
					<div class="form-group">
						<label for="message">Votre message *</label>
						<textarea class="form-control" placeholder="Ecrire ici votre message" name="" id="message" cols="30" rows="15"></textarea>
					</div>
					<div class="info" style="display:none">
						<p class="justify-content-start align-items-center" style="display:flex ;padding-left:15px; color:13px; height : 35px;"></p>
					</div>
					<div class="form-group">
						<button class="btn btn-warning btn-md" id="sendMail">
							<span>Envoyer</span>
						</button>
					</div>
				</div>
			</div>
		</form>
	</div>
</section>
